    f'  \u25b8 IRC: {IRC_SERVER}:{IRC_PORT}'
    f'  \u25b8 #ZealPalace  \u25b8 #ZealHangs  \u25b8 #RPG'
    f'  \u25b8 Yggdrasil Mesh Network'
    f'  \u25b8 Ollama AI  \u25b8 7 Models'
    f'  \u25b8 G\'day mate    '
)

# ─── Color Pairs ────────────────────────────────
C_PLASMA1 = 1; C_PLASMA2 = 2; C_PLASMA3 = 3
C_AVATAR = 4; C_AVATAR2 = 5; C_MOOD = 6; C_THOUGHT = 7
C_IRC_TS = 8; C_IRC_NICK = 9; C_IRC_ZEALOT = 10
C_IRC_MSG = 11; C_IRC_SYS = 12; C_IRC_SE = 13; C_IRC_ID = 14
C_INPUT = 15; C_TRIP = 16; C_DEATH = 17; C_SEP = 18

