#!/usr/bin/env python3
"""ZEALOT Display - Merged IRC + Avatar curses TUI (auto-sizing)

Layout (dynamic, fits any terminal size):
Row 0-1:   Animated plasma header with ZEALOT title + scrolling info
Row 2-9:   ASCII avatar (8 frames, animated eyes/spinner)
Row 10-11: Mood + thought / dream (word-wrapped, 2 lines)
Row 12:    Separator
Row 13-N:  IRC scrollback (word-wrapped, colored) — all channels merged
Last row:  Input prompt
"""
import curses, time, math, os, sys, json, random, textwrap, socket
from pathlib import Path
from datetime import datetime

os.environ['TERM'] = 'linux'

# Dimensions auto-detected from terminal
MEM_FILE  = Path.home() / '.cache' / 'zealot' / 'state.json'
IRC_LOG   = Path.home() / '.cache' / 'zealot' / 'irc.log'
RPG_LOG   = Path.home() / '.cache' / 'zealot' / 'rpg.log'
HANGS_LOG = Path.home() / '.cache' / 'zealot' / 'hangs.log'
CHAT_FIFO = Path.home() / '.cache' / 'zealot' / 'chat_in'

# ─── Network / IRC Info ─────────────────────────
NETWORK_HOST = 'Zeal.Yggdrasil.aday.net.au'
IRC_SERVER = 'ZealPalace.Yggdrasil.aday.net.au'
IRC_PORT = 6667
